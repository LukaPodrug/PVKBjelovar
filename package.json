{
  "name": "water-polo-club-admin",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "db:generate": "prisma generate --schema packages/database/prisma/schema.prisma",
    "db:migrate:dev": "prisma migrate dev --schema packages/database/prisma/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema packages/database/prisma/schema.prisma",
    "db:seed": "tsx packages/database/src/seed.ts",
    "dev": "turbo run dev --parallel",
    "dev:api": "npm --workspace apps/api run dev",
    "dev:landing": "npm --workspace apps/landing-page run dev",
    "dev:mobile": "npm --workspace apps/mobile run dev",
    "dev:web": "npm --workspace apps/admin-web run dev",
    "format": "turbo run format",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "prisma": "^6.0.0",
    "tsx": "^4.0.0",
    "turbo": "^2.0.0"
  }
}
