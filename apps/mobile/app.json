{
  "expo": {
    "name": "PVK Mladost Bjelovar",
    "slug": "pvk-mladost-bjelovar-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pvkmladostbjelovar.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "Kamera se koristi za skeniranje QR kodova za evidenciju dolazaka na trening."
      }
    },
    "android": {
      "package": "com.pvkmladostbjelovar.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.CAMERA"
      ],
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Kamera se koristi za skeniranje QR kodova za evidenciju dolazaka na trening."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#123d75"
        }
      ]
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
