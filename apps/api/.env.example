NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/water_polo_club
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
# Comma-separated list of allowed browser origins for CORS (admin-web + landing-page in production).
FRONTEND_URLS=http://localhost:5173
# Single-origin fallback used when FRONTEND_URLS is unset.
FRONTEND_URL=http://localhost:5173
MAX_UPLOAD_SIZE_MB=8
CONTENTFUL_MANAGEMENT_TOKEN=
CONTENTFUL_SPACE_ID=
CONTENTFUL_ENVIRONMENT=master
CONTENTFUL_LOCALE=en-US
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@example.com
RESEND_API_KEY=
